# --- Required ---
# PostgreSQL connection string (from Neon, Supabase, Render, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET="change-this-to-a-long-random-string"

# --- Optional ---
# Port the server listens on (Render sets this automatically).
PORT=4000

# Seed manager credentials (used by `npm run db:seed`). Change after first login!
SEED_MANAGER_EMAIL="manager@taawun-crm.local"
SEED_MANAGER_PASSWORD="manager123"
